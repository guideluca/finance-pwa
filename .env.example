# Copie para .env e preencha com os valores do Supabase (Settings → API)
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# Opcional: Google AI Studio — tier gratuito para dicas e categorização (restringe a chave por HTTP referrer)
# https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=
# Opcional (por omissão: gemini-2.0-flash)
# VITE_GEMINI_MODEL=gemini-2.0-flash

# Opcional: Groq — usado em fallback automático se o Gemini devolver quota / limite / sobrecarga
# https://console.groq.com/keys
VITE_GROQ_API_KEY=
# Opcional (ex.: llama-3.3-70b-versatile, llama-3.1-8b-instant)
# VITE_GROQ_MODEL=llama-3.3-70b-versatile
